# Copiá a .env y ajustá. JWT obligatorio para login.

JWT_SECRET=cambiar-en-produccion-minimo-32-caracteres

# --- Base con Docker (recomendado) ---
# 1) En esta carpeta: docker compose up -d
# 2) npm run db:init
# Valores por defecto del contenedor Docker (ver docker-compose.yml): sigex-api-postgres, puerto 5433.
PGHOST=127.0.0.1
PGPORT=5433
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=sigex

# --- O una sola URL (p. ej. Railway) — si está definida, se ignoran PG* de arriba ---
# DATABASE_URL=postgresql://...
# SSL: por defecto está APAGADO (evita error "does not support SSL" en Postgres local).
# En Railway / hosting que exija SSL: DATABASE_SSL=true
# DATABASE_SSL=true

PORT=3001

# Cloudinary (archivos PDF/imágenes)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# En Vercel (frontend): SIGEX_REMUNERACIONES_DEV_STUB=0 en producción (no usar datos simulados)
